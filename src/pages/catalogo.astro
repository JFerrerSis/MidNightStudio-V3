---
import Layout from "../layouts/Layout.astro";
import Header from "../components/ui/Header.astro";
import CatalogComponent from "../components/info/Catalog.astro";
import CartModal from "../components/info/CartModal.astro";
---

<Layout title="Catálogo Exclusivo | Midnight Studio">
  <Header />
  
  <main class="min-h-screen bg-main-bg pt-24">
    <div id="catalog-page-wrapper">
      <CatalogComponent />
    </div>
  </main>

  <CartModal />
</Layout>

<script>
  import gsap from 'gsap';

  function initEntrance() {
    const wrapper = document.getElementById('catalog-page-wrapper');
    if (wrapper) {
      // Seteamos el estado inicial con GSAP y luego animamos
      gsap.fromTo(wrapper, 
        { 
          opacity: 0, 
          y: 30 
        }, 
        { 
          opacity: 1, 
          y: 0, 
          duration: 1, 
          ease: "expo.out",
          delay: 0.2 // Un pequeño respiro para que cargue el DOM
        }
      );
    }
  }

  // Ejecución estándar
  window.addEventListener('load', initEntrance);
  
  // Soporte por si usas ViewTransitions
  document.addEventListener('astro:page-load', initEntrance);
</script>
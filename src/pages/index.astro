---
import Layout from "../layouts/Layout.astro";
import Header from "../components/ui/Header.astro";
import Hero from "../components/info/Hero.astro";
import Services from "../components/info/Services.astro";
---

<Layout title="Midnight Studio | Impresiones de Alta Gama">
  <Header />

  <main class="relative">
    <Hero />

    <div id="content-wrapper" class="relative z-10 w-full bg-main-bg transition-colors duration-500">
      
      <section id="servicios-section" class="w-full">
        <Services />
      </section>

      </div>
  </main>
</Layout>

<style>
  /* Aseguramos que el fondo del wrapper sea consistente con el tema 
    para evitar cortes visuales entre secciones.
  */
  #content-wrapper {
    background-color: var(--bg-color, transparent);
  }
</style>
---
// src/components/info/SectionRigidos.astro
---

<section id="rigidos" class="relative min-h-[160vh] bg-midnight-text text-white">
  <div class="sticky top-0 h-screen w-full flex items-center justify-center overflow-hidden pt-20">
    
    <div class="container mx-auto px-6 grid lg:grid-cols-12 gap-12 items-center relative z-10">
      
      <div class="lg:col-span-7 relative h-[60vh] flex items-center justify-center perspective-[2500px]">
        
        <div class="rigido-layer absolute w-[80%] md:w-[75%] aspect-video rounded-2xl overflow-hidden shadow-2xl border border-white/5 z-10" data-depth="0.2">
          <img src="/images/rigidos/lamina.jpeg" alt="Lámina" class="w-full h-full object-cover grayscale-[0.5]" />
          <div class="absolute inset-0 bg-midnight-text/40"></div>
        </div>

        <div class="rigido-layer absolute w-[48%] md:w-[42%] aspect-square rounded-3xl overflow-hidden shadow-[0_30px_60px_rgba(0,0,0,0.8)] z-30 translate-x-[20%] translate-y-[15%] border-8 border-midnight-text" data-depth="1.5">
          <img src="/images/rigidos/tazablanca.jpeg" alt="Taza Blanca" class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-linear-to-tr from-white/20 to-transparent opacity-50"></div>
        </div>

        <div class="rigido-layer absolute w-[38%] md:w-[35%] aspect-square rounded-full overflow-hidden shadow-2xl z-20 -translate-x-[35%] -translate-y-[25%] border-4 border-emerald/40" data-depth="0.8">
          <img src="/images/rigidos/tazamagica.jpeg" alt="Taza Mágica" class="w-full h-full object-cover" />
        </div>
      </div>

      <div class="lg:col-span-5 z-40">
        <div class="overflow-hidden mb-4">
          <span class="text-rigidos-tag inline-block text-emerald font-black tracking-[0.5em] uppercase text-[11px] translate-y-full">
            02 — Superficies Rígidas
          </span>
        </div>
        
        <h2 class="text-rigidos-title text-6xl md:text-8xl font-serif font-black leading-[0.8] mb-8 opacity-0 -translate-x-20 uppercase tracking-tighter">
          Brillo <br/> <span class="text-emerald italic">Sólido</span>
        </h2>
        
        <div class="rigido-content-box space-y-6 max-w-sm border-l-2 border-emerald/20 pl-6 opacity-0 translate-y-10">
          <p class="text-gray-400 text-lg leading-relaxed font-sans">
            Sublimación de grado industrial. <strong class="text-white">Nitidez molecular</strong> en cada pieza.
          </p>
          <div class="flex gap-4">
             <div class="h-px w-12 bg-emerald self-center"></div>
             <span class="text-[10px] font-bold tracking-widest text-emerald uppercase">Premium Glossy Finish</span>
          </div>
        </div>
      </div>

    </div>

    <span class="rigido-watermark absolute -bottom-10 -right-20 text-[20rem] font-serif font-black text-white/2 uppercase select-none pointer-events-none z-0">
      Rigid
    </span>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: "#rigidos",
      start: "top top",
      end: "bottom bottom",
      scrub: 1.5,
      invalidateOnRefresh: true
    }
  });

  tl.to(".text-rigidos-tag", { y: 0, duration: 1 })
    .to(".text-rigidos-title", { opacity: 1, x: 0, duration: 1.2 }, "-=0.6")
    .to(".rigido-content-box", { opacity: 1, y: 0, duration: 1 }, "-=0.8");

  const layers = document.querySelectorAll('.rigido-layer');

  tl.to(layers[0], { z: -300, rotateX: 10, filter: "blur(4px)", opacity: 0.3, duration: 4 }, 0);
  tl.to(layers[1], { z: 200, x: "40%", y: "-10%", rotateY: -25, rotateX: 10, scale: 1.1, duration: 4 }, 0.1);
  tl.to(layers[2], { x: "-50%", y: "-20%", z: 100, rotateY: 15, rotateZ: -10, scale: 1.2, duration: 4 }, 0.1);

  tl.to(".rigido-watermark", { x: -150, opacity: 0.05, duration: 4 }, 0);
</script>
---
// src/components/info/CartModal.astro
import { X, Send, Package, User, Info } from '@lucide/astro';
import productosEs from "../../data/productos.json";
import productosEn from "../../data/productEn.json";

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER;

const allData = {
  es: productosEs,
  en: productosEn
};
---

<div 
  id="cart-overlay" 
  data-all-products={JSON.stringify(allData)} 
  class="fixed inset-0 bg-[#050505]/95 backdrop-blur-xl z-[999] invisible opacity-0 py-4 sm:py-10 px-2 sm:px-4 flex items-center justify-center transition-all duration-500"
>
  <div 
    id="cart-panel" 
    class="relative w-full max-w-5xl bg-modal-bg rounded-[2rem] sm:rounded-[2.5rem] overflow-hidden shadow-[0_50px_100px_-20px_rgba(0,0,0,1)] translate-y-10 transition-all duration-500 ease-out max-h-[95vh] lg:max-h-[90vh] flex flex-col"
  >
    
    <button id="close-cart" class="absolute top-4 right-4 sm:top-6 sm:right-6 z-50 p-3 sm:p-4 bg-main-text/5 hover:bg-main-text/10 rounded-full transition-all text-main-text active:scale-90 cursor-pointer">
      <X class="w-5 h-5 sm:w-6 sm:h-6" />
    </button>

    <div class="flex flex-col lg:flex-row h-full overflow-y-auto lg:overflow-hidden custom-scrollbar">
      
      <div class="w-full lg:w-1/2 p-6 sm:p-12 border-b lg:border-b-0 lg:border-r border-default-border bg-modal-bg">
        <header class="mb-8">
          <div class="inline-flex p-3 bg-cyan-500 text-black rounded-2xl mb-4 shadow-lg shadow-cyan-500/20">
            <User class="w-5 h-5 sm:w-6 sm:h-6" />
          </div>
          <h2 class="text-2xl sm:text-3xl font-black text-main-text uppercase tracking-tighter italic leading-none" data-i18n="cart.title">Finalizar Pedido</h2>
          <p class="text-[9px] sm:text-[10px] text-main-text/40 uppercase font-bold tracking-[0.3em] mt-2" data-i18n="cart.subtitle">Completa tus datos de envío</p>
        </header>

        <form id="whatsapp-form" class="space-y-5 sm:space-y-6" data-wa={whatsappNumber} novalidate>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="space-y-2">
              <label class="text-[9px] sm:text-[10px] uppercase font-black text-main-text/40 ml-2" data-i18n="cart.name">Nombre</label>
              <input type="text" id="client-name" placeholder="Ej. Alex" required minlength="3"
                class="cart-input w-full bg-main-text/5 border border-default-border p-3.5 sm:p-4 rounded-2xl text-main-text outline-none focus:border-cyan-500 transition-all text-sm font-bold placeholder:text-main-text/20" />
            </div>
            <div class="space-y-2">
              <label class="text-[9px] sm:text-[10px] uppercase font-black text-main-text/40 ml-2" data-i18n="cart.id">Cédula</label>
              <input type="text" id="client-id" placeholder="12345678" required pattern="^[0-9]{6,9}$"
                class="cart-input w-full bg-main-text/5 border border-default-border p-3.5 sm:p-4 rounded-2xl text-main-text outline-none focus:border-cyan-500 transition-all text-sm font-bold placeholder:text-main-text/20" />
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-[9px] sm:text-[10px] uppercase font-black text-main-text/40 ml-2" data-i18n="cart.phone">WhatsApp</label>
            <input type="tel" id="client-phone" placeholder="04121234567" required pattern="^[0-9]{10,15}$"
              class="cart-input w-full bg-main-text/5 border border-default-border p-3.5 sm:p-4 rounded-2xl text-main-text outline-none focus:border-cyan-500 transition-all text-sm font-bold placeholder:text-main-text/20" />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-2">
              <label class="text-[9px] sm:text-[10px] uppercase font-black text-main-text/40 ml-2" data-i18n="cart.method">Método</label>
              <select id="order-method" class="w-full bg-main-text/5 border border-default-border p-3.5 sm:p-4 rounded-2xl text-main-text text-xs font-black outline-none focus:border-cyan-500 cursor-pointer appearance-none uppercase">
                <option value="Pickup">🏪 Pickup</option>
                <option value="Delivery">🚀 Delivery</option>
              </select>
            </div>
            <div class="space-y-2">
              <label class="text-[9px] sm:text-[10px] uppercase font-black text-main-text/40 ml-2" data-i18n="cart.date">Fecha</label>
              <input type="date" id="order-date" required 
                class="cart-input w-full bg-main-text/5 border border-default-border p-3.5 sm:p-4 rounded-2xl text-main-text text-sm font-bold outline-none focus:border-cyan-500" />
            </div>
          </div>

          <div id="address-wrapper" class="hidden space-y-2">
            <label class="text-[9px] sm:text-[10px] uppercase font-black text-main-text/40 ml-2" data-i18n="cart.address">Dirección</label>
            <textarea id="order-address" placeholder="Calle, Edificio, Apto..." 
              class="cart-input w-full bg-main-text/5 border border-default-border p-3.5 sm:p-4 rounded-2xl text-main-text outline-none focus:border-cyan-500 text-sm font-medium resize-none h-20 placeholder:text-main-text/20"></textarea>
          </div>

          <div class="space-y-2">
            <label class="text-[9px] sm:text-[10px] uppercase font-black text-main-text/40 ml-2" data-i18n="cart.payment">Pago</label>
            <select id="order-payment" class="w-full bg-main-text/5 border border-default-border p-3.5 sm:p-4 rounded-2xl text-main-text text-xs font-black outline-none focus:border-cyan-500 cursor-pointer appearance-none uppercase">
              <option value="Pago Móvil">💸 Pago Móvil</option>
              <option value="Zelle">💵 Zelle</option>
              <option value="Efectivo">💰 Efectivo</option>
            </select>
          </div>
        </form>
      </div>

      <div class="w-full lg:w-1/2 p-6 sm:p-12 bg-main-text/[0.02] flex flex-col lg:h-full">
        <header class="mb-8 shrink-0">
          <div class="flex items-center gap-3 text-main-text">
             <Package class="text-cyan-500 w-5 h-5" />
             <h3 class="text-xl font-black uppercase tracking-tight italic" data-i18n="cart.summary">Resumen</h3>
          </div>
          <div class="h-1 w-12 bg-cyan-500 mt-2"></div>
        </header>

        <div id="cart-items-container" class="space-y-4 lg:overflow-y-auto lg:grow pr-2 custom-scrollbar min-h-[200px] mb-8 lg:mb-0"></div>

        <div class="mt-auto pt-8 border-t border-default-border shrink-0">
          <div class="flex justify-between items-end mb-6">
            <div class="flex flex-col">
                <span class="text-[10px] uppercase font-black text-main-text/30 tracking-widest" data-i18n="cart.total">Total</span>
                <span id="cart-total-price" class="text-3xl sm:text-4xl font-black text-cyan-500 tracking-tighter">$0.00</span>
            </div>
            <div class="flex flex-col items-end">
                <span class="text-[8px] sm:text-[9px] text-main-text/40 font-bold uppercase tracking-wider text-right italic leading-tight">
                    * Consulta la tasa del día <br class="hidden sm:block"> vía WhatsApp
                </span>
            </div>
          </div>

          <button type="submit" form="whatsapp-form" class="w-full bg-cyan-500 hover:bg-main-text hover:text-card-bg text-black font-black py-5 sm:py-6 rounded-[1.5rem] sm:rounded-3xl flex items-center justify-center gap-4 transition-all active:scale-[0.98] shadow-2xl shadow-cyan-500/20 uppercase tracking-[0.2em] text-[10px] sm:text-xs cursor-pointer">
            <Send class="w-4 h-4 sm:w-5 sm:h-5" />
            <span data-i18n="cart.send">Confirmar Pedido</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  :root { --modal-bg: #ffffff; --default-border: #f0f0f0; --main-text-color: #000000; }
  :root[data-theme="dark"], .dark { --modal-bg: #0e0e0e; --default-border: #1a1a1a; --main-text-color: #ffffff; }

  .bg-modal-bg { background-color: var(--modal-bg); }
  .border-default-border { border-color: var(--default-border); }
  .text-main-text { color: var(--main-text-color); }

  .input-error {
    border-color: #ef4444 !important;
    background-color: rgba(239, 68, 68, 0.05) !important;
  }

  .custom-scrollbar::-webkit-scrollbar { width: 4px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(6, 182, 212, 0.3); border-radius: 10px; }

  body.modal-open { overflow: hidden; }

  @media (min-width: 1024px) {
    #cart-panel { height: 85vh; }
  }

  input[type="date"]::-webkit-calendar-picker-indicator {
    filter: var(--calendar-filter);
    cursor: pointer;
  }
  :root { --calendar-filter: invert(0); }
  :root[data-theme="dark"] { --calendar-filter: invert(1); }
</style>

<script>
  import gsap from 'gsap';
  import { cartItems, removeFromCart, cartTotal, isCartOpen } from '../../store/cartStore';
  import { currentLang } from '../../store/langStore';

  const overlay = document.getElementById('cart-overlay');
  const panel = document.getElementById('cart-panel');
  const form = document.getElementById('whatsapp-form') as HTMLFormElement;
  const methodSelect = document.getElementById('order-method') as HTMLSelectElement;
  const addressWrapper = document.getElementById('address-wrapper');
  const addressField = document.getElementById('order-address') as HTMLTextAreaElement;
  const allProductsData = JSON.parse(overlay?.dataset.allProducts || '{}');

  // --- 1. CONTROL DE APERTURA ---
  isCartOpen.subscribe((open) => {
    if (open) {
      overlay?.classList.remove('invisible');
      gsap.to(overlay, { opacity: 1, duration: 0.4, ease: "power2.out" });
      gsap.fromTo(panel, { y: 30, scale: 0.98, opacity: 0 }, { y: 0, scale: 1, opacity: 1, duration: 0.5, ease: "back.out(1.2)" });
      document.body.classList.add('modal-open');
    } else {
      gsap.to(panel, { y: 20, scale: 0.98, opacity: 0, duration: 0.3 });
      gsap.to(overlay, { opacity: 0, duration: 0.3, onComplete: () => {
        overlay?.classList.add('invisible');
        document.body.classList.remove('modal-open');
      }});
    }
  });

  document.getElementById('close-cart')?.addEventListener('click', () => isCartOpen.set(false));
  overlay?.addEventListener('click', (e) => { if(e.target === overlay) isCartOpen.set(false); });

  // --- 2. VALIDACIONES ---
  const validateField = (input: HTMLInputElement | HTMLTextAreaElement) => {
    if (!input.checkValidity()) {
      input.classList.add('input-error');
      gsap.fromTo(input, { x: -4 }, { x: 4, duration: 0.1, repeat: 3, yoyo: true });
      return false;
    }
    input.classList.remove('input-error');
    return true;
  };

  form.querySelectorAll('.cart-input').forEach(input => {
    input.addEventListener('input', () => (input as HTMLElement).classList.remove('input-error'));
  });

  methodSelect?.addEventListener('change', () => {
    const isDelivery = methodSelect.value === 'Delivery';
    addressWrapper?.classList.toggle('hidden', !isDelivery);
    addressField.required = isDelivery;
  });

  // --- 3. RENDER ---
  const renderCart = () => {
    const items = cartItems.get();
    const lang = currentLang.get();
    const container = document.getElementById('cart-items-container');
    const totalDisplay = document.getElementById('cart-total-price');
    if (!container || !totalDisplay) return;

    if (items.length === 0) {
      container.innerHTML = `<div class="h-32 flex flex-col items-center justify-center opacity-20 font-black uppercase text-[10px] tracking-widest text-main-text">Vacío / Empty</div>`;
    } else {
      container.innerHTML = items.map(item => {
        const info = allProductsData[lang]?.find((p: any) => p.id === item.id);
        const displayName = info ? info.nombre : item.name;
        return `
          <div class="flex items-center gap-3 p-3 sm:p-4 bg-main-text/[0.03] border border-default-border rounded-2xl sm:rounded-3xl group">
            <img src="${item.img}" class="w-12 h-12 sm:w-16 sm:h-16 object-cover rounded-xl" />
            <div class="grow">
              <h4 class="text-[9px] sm:text-[10px] font-black text-main-text uppercase leading-tight">${displayName}</h4>
              <p class="text-cyan-500 font-black text-xs mt-0.5">$${item.price.toFixed(2)} <span class="text-main-text/20 ml-1 font-normal">x${item.quantity}</span></p>
            </div>
            <button onclick="window.deleteItem('${item.id}')" class="p-2 text-main-text/10 hover:text-red-500 transition-all cursor-pointer">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>`;
      }).join('');
    }
    totalDisplay.textContent = `$${cartTotal.get().toFixed(2)}`;
  };

  cartItems.subscribe(() => renderCart());

  // --- 4. ENVÍO WHATSAPP ---
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const lang = currentLang.get();
    const items = cartItems.get();

    if (items.length === 0) return alert('Carrito vacío');

    const inputs = form.querySelectorAll('input[required], textarea[required]');
    let isValid = true;
    inputs.forEach((input: any) => { if (!validateField(input)) isValid = false; });
    if (!isValid) return;

    const name = (document.getElementById('client-name') as HTMLInputElement).value;
    const id = (document.getElementById('client-id') as HTMLInputElement).value;
    const phone = (document.getElementById('client-phone') as HTMLInputElement).value;
    const method = methodSelect.value;
    const payment = (document.getElementById('order-payment') as HTMLSelectElement).value;
    const date = (document.getElementById('order-date') as HTMLInputElement).value;
    const address = addressField.value;

    let msg = `*✨ MIDNIGHT STUDIO - PEDIDO ✨*\n\n`;
    msg += `👤 *Cliente:* ${name}\n`;
    msg += `🆔 *Cédula:* ${id}\n`;
    msg += `📱 *WhatsApp:* ${phone}\n`;
    msg += `📅 *Fecha:* ${date}\n`;
    msg += `📍 *Método:* ${method}\n`;
    if(method === 'Delivery') msg += `🏠 *Dirección:* ${address}\n`;
    msg += `💳 *Pago:* ${payment}\n\n`;
    msg += `📦 *PRODUCTOS:*\n`;
    items.forEach(i => { msg += `• ${i.quantity}x ${i.name} ($${(i.price * i.quantity).toFixed(2)})\n`; });
    msg += `\n💰 *TOTAL: $${cartTotal.get().toFixed(2)}*`;
    msg += `\n\n⚠️ _Nota: Consultar tasa del día para pagos en Bs._`;

    window.open(`https://wa.me/${form.dataset.wa}?text=${encodeURIComponent(msg)}`, '_blank');
  });

  (window as any).deleteItem = (id: string) => removeFromCart(id);
</script>
---
// src/components/info/Contact.astro
import { Send, Mail, MapPin } from '@lucide/astro';

const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || "584120000000"; 
const whatsappLink = `https://wa.me/${whatsappNumber}`;
---

<section id="contacto" class="relative py-12 md:py-24 px-4 sm:px-6 bg-main-bg overflow-hidden transition-colors duration-500">
  <div id="bg-circle" class="absolute top-0 right-0 w-64 h-64 md:w-125 md:h-125 bg-cyan-500/5 rounded-full blur-[80px] md:blur-[120px] pointer-events-none"></div>

  <div class="container mx-auto max-w-7xl relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
      
      <div class="flex flex-col justify-center text-left">
        <div class="contact-reveal">
          <div class="inline-flex items-center gap-3 mb-4 md:mb-6">
            <span class="h-px w-6 md:w-8 bg-cyan-500"></span>
            <span class="text-[9px] md:text-[10px] font-black uppercase tracking-[0.3em] md:tracking-[0.4em] text-cyan-500" data-i18n="contact.subtitle">Hablemos de tu marca</span>
          </div>
          <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-main-text tracking-tighter uppercase italic mb-6 md:mb-8 leading-[0.95] md:leading-[0.9]" data-i18n="contact.title">
            Transforma tus <br class="hidden sm:block"/> ideas en materia
          </h2>
        </div>

        <div class="space-y-6 md:space-y-8 mb-10 md:mb-12">
          <div class="contact-reveal flex items-center gap-4 md:gap-6 group">
            <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl md:rounded-2xl bg-main-text/5 flex items-center justify-center border border-main-text/10 group-hover:border-cyan-500/50 transition-all">
              <Mail class="w-4 h-4 md:w-5 md:h-5 text-cyan-500" />
            </div>
            <div>
              <p class="text-[8px] md:text-[10px] uppercase tracking-widest text-main-text/40 font-bold">Email</p>
              <p class="text-sm md:text-base text-main-text font-medium break-all">midnightstudio1513@gmail.com</p>
            </div>
          </div>
          <div class="contact-reveal flex items-center gap-4 md:gap-6 group">
            <div class="w-10 h-10 md:w-12 md:h-12 rounded-xl md:rounded-2xl bg-main-text/5 flex items-center justify-center border border-main-text/10 group-hover:border-cyan-500/50 transition-all">
              <MapPin class="w-4 h-4 md:w-5 md:h-5 text-cyan-500" />
            </div>
            <div>
              <p class="text-[8px] md:text-[10px] uppercase tracking-widest text-main-text/40 font-bold">Ubicación</p>
              <p class="text-sm md:text-base text-main-text font-medium">Maracaibo, Venezuela</p>
            </div>
          </div>
        </div>

        <div class="contact-reveal flex">
            <a href={whatsappLink} target="_blank" class="w-10 h-10 md:w-12 md:h-12 rounded-full border border-main-text/10 flex items-center justify-center hover:bg-[#25D366] hover:text-white transition-all duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </a>
        </div>
      </div>

      <div class="relative w-full" id="form-card">
        <div class="p-6 sm:p-8 md:p-12 rounded-4xl md:rounded-[2.5rem] bg-main-text/3 backdrop-blur-3xl border border-main-text/5 shadow-2xl relative overflow-hidden">
          
          <form id="midnight-contact-form" action="https://formspree.io/f/mjgpdjlp" method="POST" class="space-y-4 md:space-y-6 relative z-10">
            <div class="space-y-1.5 md:space-y-2 contact-reveal">
              <label class="text-[8px] md:text-[10px] uppercase tracking-widest font-black text-main-text/40 ml-2 md:ml-4" data-i18n="contact.name">Nombre / Empresa</label>
              <input type="text" name="name" required class="w-full px-4 md:px-6 py-3 md:py-4 rounded-xl md:rounded-2xl bg-main-bg border border-main-text/10 focus:border-cyan-500 outline-none text-sm md:text-base text-main-text transition-all" />
            </div>

            <div class="space-y-1.5 md:space-y-2 contact-reveal">
              <label class="text-[8px] md:text-[10px] uppercase tracking-widest font-black text-main-text/40 ml-2 md:ml-4" data-i18n="contact.email">Correo Electrónico</label>
              <input type="email" name="email" required class="w-full px-4 md:px-6 py-3 md:py-4 rounded-xl md:rounded-2xl bg-main-bg border border-main-text/10 focus:border-cyan-500 outline-none text-sm md:text-base text-main-text transition-all" />
            </div>

            <div class="space-y-1.5 md:space-y-2 contact-reveal">
              <label class="text-[8px] md:text-[10px] uppercase tracking-widest font-black text-main-text/40 ml-2 md:ml-4" data-i18n="contact.message">Tu idea...</label>
              <textarea name="message" rows="4" required class="w-full px-4 md:px-6 py-3 md:py-4 rounded-xl md:rounded-2xl bg-main-bg border border-main-text/10 focus:border-cyan-500 outline-none text-sm md:text-base text-main-text resize-none transition-all"></textarea>
            </div>

            <button type="submit" id="submit-btn" class="w-full py-4 md:py-5 bg-main-text text-main-bg rounded-xl md:rounded-2xl font-black text-[9px] md:text-[10px] uppercase tracking-[0.3em] md:tracking-[0.4em] flex items-center justify-center gap-3 hover:opacity-90 active:scale-95 transition-all">
              <span data-i18n="contact.send">Enviar Solicitud</span>
              <Send class="w-3 h-3 md:w-4 md:h-4" />
            </button>
          </form>
          
          <div id="form-success" class="hidden absolute inset-0 bg-main-bg/95 backdrop-blur-xl z-20  flex-col items-center justify-center text-center p-4">
             <div class="success-content flex flex-col items-center">
                <div class="w-14 h-14 md:w-20 md:h-20 bg-cyan-500 rounded-full flex items-center justify-center text-black mb-4 md:mb-6 shadow-lg">
                   <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-10 md:h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <h3 class="text-sm md:text-base text-main-text font-black uppercase tracking-[0.2em]" data-i18n="contact.success_title">¡Uff! Enviado</h3>
             </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { currentLang, translations, type Language } from '../../store/langStore';

  gsap.registerPlugin(ScrollTrigger);

  const initContact = () => {
    // 1. Animación de Entrada Escalonada (Stagger)
    gsap.from(".contact-reveal", {
      scrollTrigger: {
        trigger: "#contacto",
        start: "top 80%",
      },
      y: 30,
      opacity: 0,
      duration: 1,
      stagger: 0.15,
      ease: "expo.out"
    });

    // 2. Animación de la Tarjeta del Formulario
    gsap.from("#form-card", {
      scrollTrigger: {
        trigger: "#form-card",
        start: "top 85%",
      },
      x: 50,
      opacity: 0,
      duration: 1.5,
      ease: "power4.out"
    });

    // 3. Movimiento Sutil del Círculo de Fondo (Floating)
    gsap.to("#bg-circle", {
      y: 40,
      x: -20,
      duration: 5,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut"
    });

    // --- Lógica del Formulario ---
    const form = document.getElementById('midnight-contact-form') as HTMLFormElement;
    const successMsg = document.getElementById('form-success');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const originalContent = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerText = "...";

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' }
        });

        if (response.ok) {
          // Animación de Éxito con GSAP
          successMsg?.classList.remove('hidden');
          successMsg?.classList.add('flex');
          
          gsap.from(".success-content", {
            scale: 0.5,
            opacity: 0,
            duration: 0.6,
            ease: "back.out(1.7)"
          });

          form.reset();

          setTimeout(() => {
            gsap.to(successMsg, {
              opacity: 0,
              duration: 0.5,
              onComplete: () => {
                successMsg?.classList.add('hidden');
                successMsg?.classList.remove('flex');
                gsap.set(successMsg, { opacity: 1 });
              }
            });
          }, 4000);
        }
      } catch (error) {
        console.error("Error");
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalContent;
      }
    });

    // Idioma
    currentLang.subscribe((lang: Language) => {
      const content = translations[lang]?.contact;
      if (!content) return;
      document.querySelectorAll('[data-i18n^="contact."]').forEach(el => {
        const key = el.getAttribute('data-i18n')?.split('.')[1];
        if (key && content[key]) {
          if (key === 'title') el.innerHTML = content[key];
          else (el as HTMLElement).innerText = content[key];
        }
      });
    });
  };

  document.addEventListener('astro:page-load', initContact);
  if (document.readyState !== 'loading') initContact();
</script>
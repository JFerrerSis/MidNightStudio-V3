---
import { Shirt, Coffee, Palette, Image as ImageIcon, Layout, Box } from '@lucide/astro';

const services = [
  { id: 0, icon: Shirt },
  { id: 1, icon: Coffee },
  { id: 2, icon: Palette },
  { id: 3, icon: ImageIcon },
  { id: 4, icon: Layout },
  { id: 5, icon: Box }
];
---

<section id="servicios" class="relative py-16 px-4 sm:px-6 overflow-hidden bg-main-bg transition-colors duration-500">
  <div class="max-w-6xl mx-auto">
    
    <div class="text-center mb-10 space-y-3 reveal-header">
      <h3 class="text-3xl sm:text-5xl font-bold text-main-text tracking-tight" data-i18n="services.mainTitle">
        Servicios de <span class="text-transparent bg-clip-text bg-linear-to-r from-cyan-400 to-cyan-600">Personalización</span>
      </h3>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-8">
      {services.map((service) => (
        <div 
          class="service-card group relative p-5 sm:p-8 rounded-4xl bg-card-bg border border-white/10 transition-all duration-300 hover:-translate-y-2 active:scale-95 flex flex-col items-center text-center lg:items-start lg:text-left h-full shadow-lg hover:shadow-cyan-500/20"
          data-service-index={service.id}
        >
          <div class="mb-4 sm:mb-6 relative w-12 h-12 sm:w-16 sm:h-16 flex items-center justify-center rounded-2xl bg-cyan-500/10 text-cyan-500 group-hover:bg-cyan-500 group-hover:text-white transition-all duration-500 shrink-0">
            <service.icon class="w-6 h-6 sm:w-8 sm:h-8" />
          </div>

          <div class="flex flex-col grow w-full">
            <h4 class="service-title text-sm sm:text-xl font-bold text-main-text mb-2 group-hover:text-cyan-500 transition-colors uppercase tracking-tight leading-snug">
              ---
            </h4>
            
            <p class="service-desc text-[11px] sm:text-sm text-main-text/60 leading-relaxed font-medium line-clamp-3 sm:line-clamp-none">
              ---
            </p>
          </div>

          <div class="mt-5 w-8 h-1 bg-cyan-500/30 group-hover:w-full group-hover:bg-cyan-500 transition-all duration-500 rounded-full"></div>

          <div class="absolute inset-0 bg-radial-gradient from-cyan-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { currentLang, type Language } from '../../store/langStore';

  gsap.registerPlugin(ScrollTrigger);

  const serviceTranslations = {
    es: {
      mainTitle: "Servicios de Personalización",
      titles: ["Textil & Estampado", "Mugs & Tazas", "Diseño Gráfico", "Fotos Polaroid", "Láminas de Aluminio", "Papelería Creativa"],
      descs: [
        "Sublimación y DFT de alta definición en prendas.",
        "Personalización premium de tazas y termos.",
        "Vectorización y artes listos para impresión.",
        "Fotos tipo Polaroid con laminado protector.",
        "Impresiones de lujo sobre metal y placas.",
        "Stickers y empaques para tu marca."
      ]
    },
    en: {
      mainTitle: "Custom Services",
      titles: ["Apparel & Print", "Mugs & Cups", "Graphic Design", "Polaroid Style", "Aluminum Prints", "Creative Stationery"],
      descs: [
        "High-definition sublimation and DFT printing.",
        "Premium custom mugs with vibrant finishes.",
        "Professional vectorization and art design.",
        "Polaroid-style photos with UV protection.",
        "Luxury metal prints for awards and decor.",
        "Custom stickers and branded packaging."
      ]
    }
  };

  const updateContent = (lang: Language) => {
    const mainTitle = document.querySelector('[data-i18n="services.mainTitle"]');
    if (mainTitle) {
      const text = serviceTranslations[lang].mainTitle;
      const words = text.split(' ');
      const lastWord = words.pop();
      mainTitle.innerHTML = `${words.join(' ')} <span class="text-transparent bg-clip-text bg-linear-to-r from-cyan-400 to-cyan-600">${lastWord}</span>`;
    }

    document.querySelectorAll('[data-service-index]').forEach(el => {
      const idx = parseInt(el.getAttribute('data-service-index') || '0');
      const title = el.querySelector('.service-title');
      const desc = el.querySelector('.service-desc');
      if (title) title.textContent = serviceTranslations[lang].titles[idx];
      if (desc) desc.textContent = serviceTranslations[lang].descs[idx];
    });
  };

  const initAnimations = () => {
    // Animación de entrada más suave para móviles
    gsap.from(".service-card", {
      scrollTrigger: {
        trigger: "#servicios",
        start: "top 80%",
      },
      y: 30,
      opacity: 0,
      stagger: 0.08,
      duration: 0.8,
      ease: "power2.out",
      clearProps: "all"
    });

    gsap.from(".reveal-header", {
      scrollTrigger: {
        trigger: "#servicios",
        start: "top 90%",
      },
      y: 20,
      opacity: 0,
      duration: 1
    });
  };

  currentLang.subscribe(updateContent);
  
  document.addEventListener('astro:page-load', () => {
    updateContent(currentLang.get());
    initAnimations();
  });
</script>

<style>
  @reference "../../styles/global.css";

  :root { --card-bg: #ffffff; --main-bg: #f8fafc; }
  :root[data-theme="dark"] { --card-bg: #0f172a; --main-bg: #020617; }

  .bg-main-bg { background-color: var(--main-bg); }
  .bg-card-bg { background-color: var(--card-bg); }

  .service-card {
    backdrop-filter: blur(8px);
    /* Sutil borde neón en dark mode */
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
  }

  [data-theme="dark"] .service-card {
    border: 1px solid rgba(6, 182, 212, 0.1);
  }
</style>
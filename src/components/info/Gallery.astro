---
// src/components/info/Gallery.astro

// Rutas exactas a tus archivos
const works = [
  { src: "/images/textil/oversize.jpeg", cat: "Textil" },
  { src: "/images/rigidos/tazamagica.jpeg", cat: "Rígidos" },
  { src: "/images/fotografia/polaroid3.jpeg", cat: "Diseño Gráfico" },
  { src: "/images/rigidos/lamina.jpeg", cat: "Estampados" },
  { src: "/images/textil/algodon.jpeg", cat: "Oversize" },
];
---

<section id="galeria" class="relative py-24 bg-main-bg overflow-hidden transition-colors duration-500">
  <div class="container mx-auto px-6 mb-12">
    <div class="flex flex-col items-center text-center">
      <span class="text-[10px] font-black uppercase tracking-[0.5em] text-cyan-500 mb-4" data-i18n="gallery.subtitle">Proyectos Recientes</span>
      <h2 class="text-4xl sm:text-6xl font-bold text-main-text tracking-tighter uppercase italic" data-i18n="gallery.title">Showcase Creativo</h2>
    </div>
  </div>

  <div class="gallery-container relative w-full overflow-hidden">
    <div class="gallery-track flex gap-6 w-max" id="gallery-track">
      {works.map((work) => (
        <div class="gallery-item relative shrink-0 w-75 sm:w-112.5 aspect-4/5 rounded-4xl overflow-hidden border border-main-text/5 group">
          <img 
            src={work.src} 
            alt={work.cat} 
            class="w-full h-full object-cover grayscale-[0.3] group-hover:grayscale-0 group-hover:scale-110 transition-all duration-700 ease-out"
          />
          <div class="absolute inset-0 bg-linear-to-t from-black/90 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-8">
            <span class="text-cyan-400 text-[10px] font-black uppercase tracking-widest mb-2">{work.cat}</span>
            <button class="text-white text-xs font-bold uppercase tracking-[0.2em] flex items-center gap-2">
               <span data-i18n="gallery.viewWork">Ver Detalle</span>
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { currentLang, translations, type Language } from '../../store/langStore';

  const initGallery = () => {
    const track = document.getElementById('gallery-track') as HTMLElement;
    if (!track) return;

    // 1. Clonamos el contenido para el loop infinito visual
    const items = Array.from(track.children);
    items.forEach(item => {
      const clone = item.cloneNode(true);
      track.appendChild(clone);
    });

    // 2. Animación Automática con GSAP (Independiente del Scroll)
    const totalWidth = track.scrollWidth / 2;
    
    // Creamos la animación constante
    const animation = gsap.to(track, {
      x: -totalWidth,
      duration: 35, // Velocidad de la cinta (más alto = más lento)
      ease: "none",
      repeat: -1,
    });

    // 3. Interacción: Pausar al poner el mouse (para ver detalles)
    track.addEventListener("mouseenter", () => {
      gsap.to(animation, { timeScale: 0, duration: 0.5, ease: "power2.out" });
    });

    track.addEventListener("mouseleave", () => {
      gsap.to(animation, { timeScale: 1, duration: 0.8, ease: "power2.in" });
    });

    // 4. Lógica de Idioma (Nanostores)
    currentLang.subscribe((lang: Language) => {
      const content = translations[lang]?.gallery;
      if (!content) return;
      document.querySelectorAll('[data-i18n^="gallery."]').forEach(el => {
        const key = el.getAttribute('data-i18n')?.split('.')[1];
        if (key && content[key]) el.textContent = content[key];
      });
    });
  };

  document.addEventListener('astro:page-load', initGallery);
  if (document.readyState !== 'loading') initGallery();
</script>

<style>
  /* Evita que el track se rompa en varias líneas */
  .gallery-track {
    display: flex;
    flex-wrap: nowrap;
    will-change: transform;
  }

  /* Sombra elegante para resaltar las fotos en modo oscuro */
  :root[data-theme="dark"] .gallery-item {
    box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.7);
  }
</style>
---
import productosEs from "../../data/productos.json";
import productosEn from "../../data/productEn.json";
import ProductCard from "../ui/ProductCard.astro"; 

const allData = {
  es: productosEs,
  en: productosEn
};

// Generamos las categorías iniciales (ES) para el primer renderizado del servidor
const initialCategories = ["Todos", ...new Set(productosEs.map(p => p.categoria))];
---

<div id="catalog-root" data-products={JSON.stringify(allData)}>
  <div class="max-w-7xl mx-auto px-4 sm:px-8 py-12">
    <div class="flex flex-col lg:flex-row gap-12">
      
      <aside class="lg:w-64 shrink-0">
        <div class="sticky top-32 space-y-8">
          <div>
            <h3 class="text-4xl font-bold text-main-text tracking-tighter italic">Midnight Studio</h3>
          </div>
          
          <div id="category-filters" class="flex flex-row lg:flex-col gap-2 overflow-x-auto lg:overflow-visible pb-4 lg:pb-0 scrollbar-hide">
            {initialCategories.map(cat => (
              <button 
                class="filter-btn text-left px-6 py-3 rounded-2xl border border-main-text/10 bg-main-text/5 text-main-text text-[10px] font-bold uppercase tracking-widest hover:border-cyan-500 hover:text-cyan-500 transition-all cursor-pointer whitespace-nowrap lg:whitespace-normal"
                data-category={cat}
              >
                <span>{cat === "Todos" ? "Todos" : cat}</span>
              </button>
            ))}
          </div>
        </div>
      </aside>

      <div class="grow">
        <div class="grid grid-cols-2 md:grid-cols-2 xl:grid-cols-4 gap-4 sm:gap-8" id="product-grid">
          {productosEs.map(product => (
            <ProductCard product={product} />
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { addToCart } from '../../store/cartStore';
  import { currentLang, translations, type Language } from '../../store/langStore';
  import gsap from 'gsap';

  const root = document.getElementById('catalog-root');
  const categoryContainer = document.getElementById('category-filters');
  const allProducts = JSON.parse(root?.dataset.products || '{}');
  
  /**
   * Inicializa los eventos de clic en los botones de filtro.
   * Se usa addEventListener para evitar errores de tipado de TS y asegurar compatibilidad.
   */
  const initFilterEvents = () => {
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.product-card');

    filterBtns.forEach(btn => {
      // Usamos addEventListener para cumplir con el estándar de TS
      btn.addEventListener('click', () => {
        const category = btn.getAttribute('data-category');
        
        // UI: Limpiar clases activas y marcar el actual
        filterBtns.forEach(b => b.classList.remove('text-cyan-500', 'border-cyan-500'));
        btn.classList.add('text-cyan-500', 'border-cyan-500');

        // Animación de salida
        gsap.to(cards, {
          opacity: 0, 
          scale: 0.9, 
          duration: 0.2,
          onComplete: () => {
            cards.forEach(card => {
              const cardCat = card.dataset.cat;
              // Lógica bilingüe para el botón "Todos"
              const isAll = category === "Todos" || category === "All";
              card.style.display = (isAll || cardCat === category) ? "flex" : "none";
            });
            
            // Animación de entrada para los elementos filtrados
            gsap.to(".product-card[style*='display: flex']", { 
              opacity: 1, 
              scale: 1, 
              duration: 0.4, 
              stagger: 0.05,
              ease: "back.out(1.7)" 
            });
          }
        });
      });
    });
  };

  // --- LÓGICA DE TRADUCCIÓN REACTIVA ---
  currentLang.subscribe((lang: Language) => {
    const currentJson = allProducts[lang];
    const cards = document.querySelectorAll<HTMLElement>('.product-card');

    // 1. REGENERAR BOTONES DE CATEGORÍA DESDE EL JSON ACTUAL
    if (categoryContainer) {
      // Obtenemos categorías únicas del JSON activo
      const rawCats = [...new Set(currentJson.map((p: any) => p.categoria))];
      const translatedAll = lang === 'es' ? 'Todos' : 'All';
      
      // Construimos el HTML dinámicamente
      categoryContainer.innerHTML = `
        <button class="filter-btn text-left px-6 py-3 rounded-2xl border border-main-text/10 bg-main-text/5 text-main-text text-[10px] font-bold uppercase tracking-widest hover:border-cyan-500 hover:text-cyan-500 transition-all cursor-pointer whitespace-nowrap lg:whitespace-normal" data-category="${translatedAll}">
          <span>${translatedAll}</span>
        </button>
        ${rawCats.map(cat => `
          <button class="filter-btn text-left px-6 py-3 rounded-2xl border border-main-text/10 bg-main-text/5 text-main-text text-[10px] font-bold uppercase tracking-widest hover:border-cyan-500 hover:text-cyan-500 transition-all cursor-pointer whitespace-nowrap lg:whitespace-normal" data-category="${cat}">
            <span>${cat}</span>
          </button>
        `).join('')}
      `;
      
      // RE-VINCULAMOS los eventos porque los botones anteriores fueron borrados del DOM
      initFilterEvents();
    }

    // 2. ACTUALIZAR CARDS (Textos y data-cat)
    cards.forEach(card => {
      const id = card.dataset.id;
      const info = currentJson.find((p: any) => p.id === id);

      if (info) {
        // Actualizamos el atributo de categoría para que el filtro funcione con el nombre del JSON actual
        card.dataset.cat = info.categoria; 
        
        const title = card.querySelector('.product-title');
        const desc = card.querySelector('.product-desc');
        const btn = card.querySelector('.add-to-cart-btn');

        if (title) title.textContent = info.nombre;
        if (desc) desc.textContent = info.descripcion;
        
        // Actualizamos el objeto del producto para el carrito
        if (btn) btn.setAttribute('data-product', JSON.stringify(info));
      }
    });

    // 3. TEXTOS ESTÁTICOS (data-i18n)
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (!key) return;
      const keys = key.split('.');
      let text: any = translations[lang];
      keys.forEach(k => { text = text?.[k]; });
      if (text) el.textContent = text;
    });
  });

  // 4. GESTIÓN DEL CARRITO
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const btn = target.closest('.add-to-cart-btn');
    if (!btn) return;

    const data = JSON.parse(btn.getAttribute('data-product') || '{}');
    
    addToCart({ 
      id: data.id, 
      name: data.nombre, 
      price: data.precio, 
      img: data.imagen, 
      quantity: 1 
    });

    // Feedback visual elástico
    gsap.fromTo(btn, { scale: 0.8 }, { scale: 1, duration: 0.4, ease: "elastic.out(1, 0.3)" });
  });
</script>
---
// src/components/ui/ProductCard.astro
const { product } = Astro.props;
import { Plus, Check } from '@lucide/astro';
---

<div 
  class="product-card group flex flex-col h-full bg-card-bg rounded-[2.5rem] border border-main-text/10 overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.3)] dark:hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.6)]" 
  data-id={product.id}
  data-cat={product.categoria}
>
  <div class="relative aspect-4/5 overflow-hidden bg-main-text/5">
    <img 
      src={product.imagen} 
      alt={product.nombre} 
      class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" 
      loading="lazy" 
    />
    
    <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 flex flex-col justify-end p-8">
      <span class="text-cyan-500 text-[10px] font-black uppercase tracking-[0.2em] mb-2 translate-y-4 group-hover:translate-y-0 transition-transform duration-500">Detalles</span>
      <p class="product-desc text-white/80 text-[11px] leading-relaxed italic translate-y-4 group-hover:translate-y-0 transition-transform duration-700 delay-75">
        {product.descripcion}
      </p>
    </div>

    <div class="absolute top-6 left-6">
        <span class="bg-black/20 backdrop-blur-md border border-white/10 text-white text-[9px] font-black uppercase tracking-[0.2em] px-3 py-1.5 rounded-full opacity-0 group-hover:opacity-100 transition-all duration-500">
            {product.categoria}
        </span>
    </div>
  </div>
  
  <div class="p-7 flex flex-col grow justify-between bg-card-bg transition-colors duration-500">
    <div class="mb-4">
      <h4 class="product-title text-sm font-bold text-main-text uppercase tracking-tight leading-tight group-hover:text-cyan-500 transition-colors duration-300">
        {product.nombre}
      </h4>
    </div>

    <div class="flex items-center justify-between">
      <div class="flex flex-col">
        <span class="text-[9px] text-main-text/30 uppercase font-black tracking-widest leading-none mb-1" data-i18n="product.price">Precio</span>
        <span class="text-2xl font-black text-main-text tracking-tighter">
          ${product.precio.toFixed(2)}
        </span>
      </div>

      <button 
        class="add-to-cart-btn relative overflow-hidden p-4 rounded-2xl bg-button-bg text-button-text hover:bg-cyan-500 hover:text-black transition-all duration-300 active:scale-95 cursor-pointer shadow-xl shadow-cyan-500/5 group/btn border border-main-text/5"
        data-product={JSON.stringify(product)}
        title="Agregar a la comanda"
      >
        <div class="btn-content relative flex items-center justify-center pointer-events-none">
            <Plus class="w-5 h-5 plus-icon transition-transform duration-300" />
            <Check class="w-5 h-5 check-icon absolute translate-y-10 opacity-0 transition-all duration-300" />
        </div>
      </button>
    </div>
  </div>
</div>

<style>
  :root {
    --button-bg: #000000;
    --button-text: #ffffff;
  }

  :root[data-theme="dark"] {
    --button-bg: #ffffff;
    --button-text: #000000;
  }

  .bg-button-bg { background-color: var(--button-bg); }
  .text-button-text { color: var(--button-text); }

  .add-to-cart-btn:hover .plus-icon {
    transform: rotate(90deg);
  }
</style>

<script>
  import { addToCart } from '../../store/cartStore';
  import gsap from 'gsap';

  // Usamos delegación de eventos para evitar problemas al filtrar productos
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.add-to-cart-btn');
    if (!btn) return;

    e.preventDefault();
    // Leemos la data actualizada (el script del catálogo la cambia al cambiar idioma)
    const data = JSON.parse(btn.getAttribute('data-product') || '{}');
    
    addToCart({
      id: data.id,
      name: data.nombre,
      price: data.precio,
      img: data.imagen,
      quantity: 1
    });

    // --- ANIMACIÓN DE FEEDBACK ---
    const plusIcon = btn.querySelector('.plus-icon');
    const checkIcon = btn.querySelector('.check-icon');

    const tl = gsap.timeline();

    tl.to(plusIcon, { y: -20, opacity: 0, duration: 0.2 })
      .to(checkIcon, { y: 0, opacity: 1, duration: 0.3, ease: "back.out(2)" }, "-=0.1")
      .to(btn, { backgroundColor: "#06b6d4", color: "#000", duration: 0.2 }, "-=0.3")
      .to(checkIcon, { y: 20, opacity: 0, duration: 0.2, delay: 0.8 })
      .to(plusIcon, { y: 0, opacity: 1, duration: 0.2 })
      .to(btn, { backgroundColor: "", color: "", duration: 0.2 }, "-=0.2");
  });
</script>
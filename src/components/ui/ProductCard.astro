---
// src/components/ui/ProductCard.astro
const { product } = Astro.props;
import { Plus, Check } from '@lucide/astro';
---

<div 
  class="product-card group flex flex-col h-full bg-card-bg rounded-[1.8rem] sm:rounded-[2.5rem] border border-main-text/10 overflow-hidden transition-all duration-500 md:hover:-translate-y-2 md:hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.3)] dark:md:hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.6)]" 
  data-id={product.id}
  data-cat={product.categoria}
>
  <div class="relative aspect-4/5 overflow-hidden bg-main-text/5">
    <img 
      src={product.imagen} 
      alt={product.nombre} 
      class="w-full h-full object-cover transition-transform duration-1000 md:group-hover:scale-110" 
      loading="lazy" 
    />
    
    <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/20 to-transparent opacity-0 md:group-hover:opacity-100 transition-all duration-500 flex flex-col justify-end p-4 sm:p-8">
      <span class="text-cyan-500 text-[9px] sm:text-[10px] font-black uppercase tracking-[0.2em] mb-1 sm:mb-2 translate-y-4 md:group-hover:translate-y-0 transition-transform duration-500">Detalles</span>
      <p class="product-desc text-white/80 text-[10px] sm:text-[11px] leading-relaxed italic translate-y-4 md:group-hover:translate-y-0 transition-transform duration-700 delay-75 line-clamp-3 sm:line-clamp-none">
        {product.descripcion}
      </p>
    </div>

    <div class="absolute top-3 left-3 sm:top-6 sm:left-6">
        <span class="bg-black/40 backdrop-blur-md border border-white/10 text-white text-[7px] sm:text-[9px] font-black uppercase tracking-[0.15em] px-2 sm:px-3 py-1 sm:py-1.5 rounded-full">
            {product.categoria}
        </span>
    </div>
  </div>
  
  <div class="p-4 sm:p-7 flex flex-col grow justify-between bg-card-bg transition-colors duration-500">
    <div class="mb-3 sm:mb-4">
      <h4 class="product-title text-[11px] sm:text-sm font-bold text-main-text uppercase tracking-tight leading-tight md:group-hover:text-cyan-500 transition-colors duration-300 line-clamp-2">
        {product.nombre}
      </h4>
    </div>

    <div class="flex items-center justify-between gap-2">
      <div class="flex flex-col">
        <span class="text-[7px] sm:text-[9px] text-main-text/30 uppercase font-black tracking-widest leading-none mb-1" data-i18n="product.price">Precio</span>
        <span class="text-lg sm:text-2xl font-black text-main-text tracking-tighter">
          ${product.precio.toFixed(2)}
        </span>
      </div>

      <button 
        class="add-to-cart-btn relative overflow-hidden p-3.5 sm:p-4 rounded-xl sm:rounded-2xl bg-button-bg text-button-text md:hover:bg-cyan-500 md:hover:text-black transition-all duration-300 active:scale-90 cursor-pointer shadow-lg border border-main-text/5 shrink-0"
        data-product={JSON.stringify(product)}
      >
        <div class="btn-content relative flex items-center justify-center pointer-events-none">
            <Plus class="w-4 h-4 sm:w-5 sm:h-5 plus-icon transition-transform duration-300" />
            <Check class="w-4 h-4 sm:w-5 sm:h-5 check-icon absolute translate-y-10 opacity-0 transition-all duration-300" />
        </div>
      </button>
    </div>
  </div>
</div>

<style>
  :root {
    --button-bg: #000000;
    --button-text: #ffffff;
  }

  :root[data-theme="dark"] {
    --button-bg: #ffffff;
    --button-text: #000000;
  }

  .bg-button-bg { background-color: var(--button-bg); }
  .text-button-text { color: var(--button-text); }

  /* Solo aplicar hover rotate en dispositivos con puntero (PC) */
  @media (hover: hover) {
    .add-to-cart-btn:hover .plus-icon {
      transform: rotate(90deg);
    }
  }

  /* Evitar que el título rompa el layout */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  import { addToCart } from '../../store/cartStore';
  import gsap from 'gsap';

  const setupCartButtons = () => {
    const cartButtons = document.querySelectorAll('.add-to-cart-btn');

    cartButtons.forEach((btn) => {
      const button = btn as HTMLButtonElement;
      
      // Limpiamos cualquier rastro previo para evitar duplicados
      button.onclick = null; 

      button.onclick = (e) => {
        e.preventDefault();
        e.stopImmediatePropagation();

        // Bloqueo de seguridad mientras la animación sucede
        if (button.dataset.animating === "true") return;
        button.dataset.animating = "true";

        // 1. Lógica de datos
        const data = JSON.parse(button.getAttribute('data-product') || '{}');
        addToCart({
          id: data.id,
          name: data.nombre,
          price: data.precio,
          img: data.imagen,
          quantity: 1
        });

        // 2. Animación con GSAP Context (Limpia automáticamente al terminar)
        const plusIcon = button.querySelector('.plus-icon');
        const checkIcon = button.querySelector('.check-icon');

        let ctx = gsap.context(() => {
          const tl = gsap.timeline({
            onComplete: () => { 
              button.dataset.animating = "false";
              ctx.revert(); // Opcional: revierte estilos inline si prefieres que el CSS original tome el mando total
            }
          });

          tl.to(plusIcon, { 
            y: -20, 
            opacity: 0, 
            duration: 0.15, 
            ease: "power2.in" 
          })
          .to(checkIcon, { 
            y: 0, 
            opacity: 1, 
            duration: 0.25, 
            ease: "back.out(2)" 
          }, "-=0.1")
          .to(button, { 
            backgroundColor: "#06b6d4", 
            color: "#000", 
            borderColor: "transparent", 
            duration: 0.2 
          }, "-=0.25")
          // Pausa con el check visible
          .to(checkIcon, { 
            y: 20, 
            opacity: 0, 
            duration: 0.15, 
            delay: 0.8 
          })
          .to(plusIcon, { 
            y: 0, 
            opacity: 1, 
            duration: 0.15, 
            ease: "power2.out" 
          })
          .to(button, { 
            backgroundColor: "", // Vuelve al valor del CSS (variable o clase)
            color: "", 
            borderColor: "", 
            duration: 0.2 
          }, "-=0.15");
        }, button); // El segundo parámetro limita el alcance al botón actual
      };
    });
  };

  // Astro View Transitions compatibility
  document.addEventListener('astro:page-load', setupCartButtons);
  setupCartButtons();
</script>
---
// src/components/ui/Footer.astro
const currentYear = new Date().getFullYear();
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || "584120000000";
const whatsappLink = `https://wa.me/${whatsappNumber}`;

const links = [
  { name: 'Inicio', href: '#inicio', i18n: 'nav.home' },
  { name: 'Servicios', href: '#servicios', i18n: 'nav.services' },
  { name: 'Nosotros', href: '#nosotros', i18n: 'nav.about' }, // <-- Agregado
  { name: 'Galería', href: '#galeria', i18n: 'nav.gallery' },
  { name: 'Contacto', href: '#contacto', i18n: 'nav.contact' },
];
---

<footer class="bg-main-bg border-t border-main-text/5 pt-20 pb-10 px-6 transition-colors duration-500">
  <div class="container mx-auto max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      
      <div class="space-y-6">
        <h2 class="text-2xl font-black tracking-tighter uppercase italic text-main-text">
          Midnight<span class="text-cyan-500">.</span>
        </h2>
        <p class="text-sm text-main-text/50 max-w-62.5 leading-relaxed" data-i18n="footer.description">
          Elevando el diseño y la producción textil a un nivel superior.
        </p>
        <div class="flex gap-4">
          <a href={whatsappLink} target="_blank" aria-label="WhatsApp" class="w-10 h-10 rounded-full border border-main-text/10 flex items-center justify-center text-main-text/40 hover:text-white hover:bg-[#25D366] hover:border-[#25D366] transition-all duration-300 group">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </a>
          
          <a href="https://instagram.com" target="_blank" aria-label="Instagram" class="w-10 h-10 rounded-full border border-main-text/10 flex items-center justify-center text-main-text/40 hover:text-white hover:bg-linear-to-tr from-[#f9ce34] via-[#ee2a7b] to-[#6228d7] hover:border-transparent transition-all duration-300 group">
            <svg 
              xmlns="http://www.w3.org/2000/svg" 
              width="18" 
              height="18" 
              viewBox="0 0 24 24" 
              fill="none" 
              stroke="currentColor" 
              stroke-width="2" 
              stroke-linecap="round" 
              stroke-linejoin="round" 
              class="group-hover:scale-110 transition-transform"
            >
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
            </svg>
          </a>
        </div>
      </div>

      <div class="space-y-6">
        <h3 class="text-[10px] font-black uppercase tracking-[0.3em] text-main-text/30" data-i18n="footer.quick_links">Enlaces Rápidos</h3>
        <ul class="space-y-4">
          {links.map(link => (
            <li>
              <a href={link.href} class="text-sm text-main-text/60 hover:text-cyan-500 transition-colors" data-i18n={link.i18n}>
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="space-y-6 lg:col-span-2">
        <h3 class="text-[10px] font-black uppercase tracking-[0.3em] text-main-text/30" data-i18n="footer.schedule_title">Horario de Atención</h3>
        <div class="p-6 rounded-3xl bg-main-text/2 border border-main-text/5 inline-block">
          <p class="text-main-text font-bold text-lg mb-1" data-i18n="footer.schedule_days">Martes a Domingo</p>
          <p class="text-cyan-500 font-mono text-xl tracking-tighter" data-i18n="footer.schedule_hours">10:00 AM - 10:00 PM</p>
        </div>
      </div>

    </div>

    <div class="pt-10 border-t border-main-text/5 flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="text-[10px] uppercase tracking-widest text-main-text/30 font-bold">
        © {currentYear} Midnight Studio. <span data-i18n="footer.rights">Todos los derechos reservados.</span>
      </p>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 bg-cyan-500 rounded-full animate-pulse shadow-[0_0_10px_#06b6d4]"></span>
        <span class="text-[10px] uppercase tracking-widest text-main-text/40 font-black">Maracaibo, VZLA</span>
      </div>
    </div>
  </div>
</footer>

<script>
  import { currentLang, translations, type Language } from '../../store/langStore';

  const initFooter = () => {
    currentLang.subscribe((lang: Language) => {
      const content = translations[lang]?.footer;
      const navContent = translations[lang]?.nav; 
      if (!content) return;

      // Traducir textos del footer
      document.querySelectorAll('[data-i18n^="footer."]').forEach(el => {
        const key = el.getAttribute('data-i18n')?.split('.')[1];
        if (key && content[key]) (el as HTMLElement).innerText = content[key];
      });

      // Traducir los links usando la store de nav
      document.querySelectorAll('[data-i18n^="nav."]').forEach(el => {
        const key = el.getAttribute('data-i18n')?.split('.')[1];
        if (key && navContent && navContent[key]) (el as HTMLElement).innerText = navContent[key];
      });
    });
  };

  document.addEventListener('astro:page-load', initFooter);
  if (document.readyState !== 'loading') initFooter();
</script>
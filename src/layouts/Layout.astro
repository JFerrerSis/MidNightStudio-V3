---
interface Props {
    title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/logodark.png" />
        
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=Playfair+Display:ital,wght@0,700;0,900;1,700;1,900&display=swap" rel="stylesheet">
        
        <title>{title}</title>
    </head>
    <body class="bg-main-bg text-main-text antialiased transition-colors duration-500">
        <slot />

        <style is:global>
            /* CONFIGURACIÓN PRO: TEORÍA DEL COLOR PARA DEGRADADOS */
            :root {
                /* Gris Gélido / Off-White Azulado para que el cian NO se lave */
                --main-bg: #cde0eb; 
                --main-text: #050505;
                --default-border: rgba(5, 5, 5, 0.1);
                --accent-cyan: #06b6d4;
                --accent-purple: #a855f7;
            }

            :root[data-theme="dark"], .dark {
                --main-bg: #050505;
                --main-text: #ffffff;
                --default-border: rgba(255, 255, 255, 0.1);
            }

            /* Aplicación de variables */
            .bg-main-bg { background-color: var(--main-bg); }
            .text-main-text { color: var(--main-text); }

            body {
                overflow-x: hidden;
                min-height: 100vh;
                /* Fuente Inter para look técnico/studio */
                font-family: 'Inter', sans-serif;
            }

            /* Estilo de selección coherente */
            ::selection {
                background-color: var(--accent-cyan);
                color: #000;
            }

            /* Scrollbar personalizada minimalista */
            ::-webkit-scrollbar {
                width: 6px;
            }
            ::-webkit-scrollbar-track {
                background: var(--main-bg);
            }
            ::-webkit-scrollbar-thumb {
                background: var(--default-border);
                border-radius: 10px;
            }
            ::-webkit-scrollbar-thumb:hover {
                background: var(--accent-cyan);
            }

            /* Utilidades para textos en cursiva (Midnight Style) */
            .font-italic-bold {
                font-family: 'Playfair Display', serif;
                font-style: italic;
            }
        </style>

        <script>
            import gsap from 'gsap';
            import { ScrollTrigger } from 'gsap/ScrollTrigger';
            gsap.registerPlugin(ScrollTrigger);

            // Evitar saltos visuales al recargar
            ScrollTrigger.config({
                autoRefreshEvents: "visibilitychange,DOMContentLoaded,load"
            });

            // Lógica para persistencia de tema (Opcional pero recomendada)
            const handleTheme = () => {
                const theme = localStorage.getItem('theme') || 'dark';
                if (theme === 'dark') {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                    document.documentElement.setAttribute('data-theme', 'light');
                }
            }
            
            handleTheme();
            document.addEventListener('astro:after-swap', handleTheme);
        </script>
    </body>
</html>